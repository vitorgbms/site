<script>
  let currentImageElement = null;
  let currentProductId = null;

  function initMap() {
    const osascoCoords = [-23.5325, -46.7916];
    const map = L.map('deliveryMap').setView(osascoCoords, 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> & CartoDB',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);
    const marker = L.marker(osascoCoords).addTo(map);
    marker.bindPopup("<b>GV Sweet</b><br>Osasco - SP<br>📍 Retirada combinada via WhatsApp").openPopup();
    L.circle(osascoCoords, { color: '#5B8A9A', fillColor: '#5B8A9A', fillOpacity: 0.1, radius: 4000 }).addTo(map);
  }

  document.addEventListener('DOMContentLoaded', function() {
    if (typeof L !== 'undefined') initMap();
    
    function checkCep() {
      const cep = document.getElementById('cepInput').value.replace(/\D/g, '');
      const resultDiv = document.getElementById('cepResult');
      
      if (cep.length === 8) {
        resultDiv.innerHTML = '<span style="color: #2E7D32; background:#E8F5E9; padding:10px 16px; border-radius:30px; display:inline-block;"><i class="fas fa-check-circle"></i> ✅ Ótimo! Fale conosco no WhatsApp para combinarmos retirada ou entrega 🎉</span>';
      } else if (cep.length > 0) {
        resultDiv.innerHTML = '<span style="color: #E65100;"><i class="fas fa-info-circle"></i> Digite um CEP válido com 8 dígitos</span>';
      } else {
        resultDiv.innerHTML = '';
      }
    }
    
    document.getElementById('checkCepBtn').addEventListener('click', checkCep);
    document.getElementById('cepInput').addEventListener('keypress', (e) => { if (e.key === 'Enter') checkCep(); });
  });

  const brownieList = [
    { id: "tradicional", name: "Tradicional", price: 9, desc: "Chocolate 70%, textura úmida e crosta delicada. O clássico que nunca falha.", img: null },
    { id: "ninho", name: "Ninho", price: 10, desc: "Cobertura cremosa de leite Ninho por cima, base de chocolate ao leite.", img: null },
    { id: "ninho-kitkat", name: "Ninho com Kit Kat", price: 11, desc: "Leite Ninho cremoso + pedaços crocantes de Kit Kat sobre o brownie.", img: null },
    { id: "nutella", name: "Nutella", price: 13, desc: "Generosa camada de Nutella® pura com avelãs crocantes.", img: null },
    { id: "ninho-nutella", name: "Ninho com Nutella", price: 15, desc: "Camada dupla: Ninho cremoso + Nutella escorrendo. O favorito da casa!", img: null }
  ];

  const specialsData = [
    { id: "caixa-brigadeiros", name: "Caixa de Brigadeiros", price: "42,90", desc: "6 unidades sortidas: Ferrero Rocher, Bombom de Uva, Biscoito Oreo, Ninho com Nutella (dois de cada). Embalagem especial.", badge: "🎁 6 bombons", img: null },
    { id: "caixa-mini-brownies", name: "Caixa de Mini Brownies", price: "46,90", desc: "4 unidades: Ferrero Rocher, Ninho com Nutella, Oreo, Paçoca. Edição dia dos namorados.", badge: "🍫 4 brownies", img: null }
  ];

  function renderProductGrid() {
    const grid = document.getElementById('brownieGrid');
    if (!grid) return;
    grid.innerHTML = '';
    brownieList.forEach(p => {
      const card = document.createElement('div');
      card.className = 'product-card';
      card.innerHTML = `
        <div class="card-media" onclick="openImageUpload(this, '${p.id}')">
          ${p.img ? `<img src="${p.img}" alt="${p.name}">` : `<div class="placeholder-icon"><i class="fas fa-camera"></i><span>Clique para adicionar foto</span></div>`}
          <div class="upload-hint"><i class="fas fa-upload"></i> Clique para trocar imagem</div>
        </div>
        <div class="card-content">
          <h4>${p.name}</h4>
          <div class="price">R$ ${p.price},00 <small>unidade</small></div>
          <div class="desc">${p.desc}</div>
          <button class="btn-wpp" data-name="${p.name}" data-price="R$ ${p.price},00"><i class="fab fa-whatsapp"></i> Solicitar pelo WhatsApp</button>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  function renderSpecialGrid() {
    const specialGrid = document.getElementById('specialGrid');
    if (!specialGrid) return;
    specialGrid.innerHTML = '';
    specialsData.forEach(item => {
      const el = document.createElement('div');
      el.className = 'special-item';
      el.innerHTML = `
        <div class="special-card-media" onclick="openImageUpload(this, '${item.id}')">
          ${item.img ? `<img src="${item.img}" alt="${item.name}">` : `<div class="placeholder-icon"><i class="fas fa-camera"></i><span>Clique para adicionar foto</span></div>`}
          <div class="upload-hint" style="position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,0.65); color:white; font-size:0.65rem; padding:6px; text-align:center;"><i class="fas fa-upload"></i> Clique para trocar imagem</div>
          <div class="heart-overlay"><i class="fas fa-heart"></i> edição especial</div>
        </div>
        <div class="card-content">
          <span class="special-label-card">${item.badge}</span>
          <h4>${item.name}</h4>
          <div class="price">R$ ${item.price}</div>
          <div class="flavor-detail" style="font-size:0.78rem; background:#F9F8F4; padding:10px 14px; border-radius:28px; margin:16px 0;">📦 ${item.desc}</div>
          <button class="btn-wpp" data-name="${item.name}" data-price="R$ ${item.price}"><i class="fab fa-whatsapp"></i> Presentear agora</button>
        </div>
      `;
      specialGrid.appendChild(el);
    });
  }

  function openImageUpload(element, productId) {
    currentImageElement = element;
    currentProductId = productId;
    document.getElementById('imageModal').style.display = 'flex';
    document.getElementById('imageUrlInput').value = '';
    document.getElementById('imageFileInput').value = '';
  }

  function closeModal() { document.getElementById('imageModal').style.display = 'none'; }

  function confirmImage() {
    const urlInput = document.getElementById('imageUrlInput').value;
    const fileInput = document.getElementById('imageFileInput').files[0];
    if (urlInput) setImage(urlInput);
    else if (fileInput) { const reader = new FileReader(); reader.onload = e => setImage(e.target.result); reader.readAsDataURL(fileInput); }
    else alert('Cole uma URL ou selecione um arquivo');
  }

  function setImage(src) {
    if (!currentImageElement) return;
    currentImageElement.innerHTML = `<img src="${src}" alt="Produto" style="width:100%; height:100%; object-fit:cover;"><div class="upload-hint"><i class="fas fa-upload"></i> Clique para trocar imagem</div>`;
    if (currentImageElement.classList.contains('special-card-media')) {
      const heart = document.createElement('div'); heart.className = 'heart-overlay'; heart.innerHTML = '<i class="fas fa-heart"></i> edição especial';
      currentImageElement.appendChild(heart);
    }
    const product = [...brownieList, ...specialsData].find(p => p.id === currentProductId);
    if (product) product.img = src;
    closeModal();
  }

  function attachButtons() {
    document.querySelectorAll('.btn-wpp').forEach(btn => {
      if (btn.hasListener) return;
      const newBtn = btn.cloneNode(true);
      if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);
      newBtn.hasListener = true;
      newBtn.addEventListener('click', e => {
        e.preventDefault();
        const name = newBtn.getAttribute('data-name'), price = newBtn.getAttribute('data-price');
        window.open(`https://wa.me/5511959183946?text=${encodeURIComponent(`Olá! Gostaria de adquirir: *${name}* - ${price}. 💫%0A%0APoderia informar disponibilidade e opções de entrega/retirada? Obrigado.`)}`, '_blank');
      });
    });
  }

  renderProductGrid(); renderSpecialGrid(); attachButtons();
  new MutationObserver(() => attachButtons()).observe(document.body, { childList: true, subtree: true });
  window.onclick = e => { if (e.target === document.getElementById('imageModal')) closeModal(); };
</script>
</body>
</html>
